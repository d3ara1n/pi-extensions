{
  "name": "@d3ara1n/pi-peek",
  "version": "1.0.0",
  "type": "module",
  "description": "Consult core extension for pi — serialize the current session and ask questions about it via the utility model (read-after-burn). Registers hooks, no tools or commands.",
  "main": "src/index.ts",
  "types": "src/types.ts",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@d3ara1n/pi-model-roles": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@d3ara1n/pi-model-roles": {
      "optional": true
    }
  },
  "dependencies": {
    "@d3ara1n/pi-model-roles": "^0.7.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/d3ara1n/pi-extensions",
    "directory": "packages/pi-peek"
  },
  "license": "MIT"
}
