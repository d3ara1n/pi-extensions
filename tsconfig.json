{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "declaration": false,
    "paths": {
      "@d3ara1n/*": ["./packages/*/src/index.ts", "./packages/*/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/index.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/*/node_modules"
  ]
}
