{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "declaration": false,
    "paths": {
      "@d3ara1n/*": ["./packages/*/src/index.ts", "./packages/*/index.ts"],
      "@earendil-works/pi-ai": ["./node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-ai/dist/index"],
      "@earendil-works/pi-agent-core": ["./node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-agent-core/dist/types"],
      "@earendil-works/pi-coding-agent": ["./node_modules/@earendil-works/pi-coding-agent/dist/index"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/index.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/*/node_modules"
  ]
}
