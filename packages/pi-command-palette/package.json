{
  "name": "@d3ara1n/pi-command-palette",
  "version": "0.2.1",
  "type": "module",
  "description": "Global command palette for pi — press Ctrl+Shift+P to search and run commands from anywhere",
  "main": "src/index.ts",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
